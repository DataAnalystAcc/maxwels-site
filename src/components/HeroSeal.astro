---
/**
 * HeroSeal.astro
 * Layered animated cyberpunk/dark metallic hero seal reconstructed from reference.
 * 
 * Layers from back to front:
 * 1. Background dark plate
 * 2. Outer engraved disc (static text & symbols)
 * 3. Outer wreath / thorn crown (slow clockwise rotation)
 * 4. Inner technical rings & binary (slow counter-clockwise rotation)
 * 5. Center BII emblem (static, metallic)
 * 6. B flicker/energy overlay (technological glitch pulse)
 * 7. Ambient scanline/noise
 */
import { siteConfig } from '../data/site';
---

<section id="hero-seal" class="hero-seal-section" aria-label="Hero Introduction">
  <!-- General atmosphere: noise and gradient -->
  <div class="seal-atmos blur-bg" aria-hidden="true"></div>
  <div class="seal-atmos noise-overlay" aria-hidden="true"></div>
  <div class="seal-atmos scanlines" aria-hidden="true"></div>

  <!-- Main scaling container for the seal graphic -->
  <div class="seal-container">
    
    <!-- SVG Canvas for all Layers -->
    <svg class="seal-svg" viewBox="-500 -500 1000 1000" xmlns="http://www.w3.org/2000/svg" aria-label="Animated BII Hero Seal">
      <defs>
        <!-- Gradients for metallic rendering -->
        <radialGradient id="plateGrad" cx="0" cy="0" r="500">
          <stop offset="0%" stop-color="#141416"/>
          <stop offset="40%" stop-color="#0a0a0c"/>
          <stop offset="100%" stop-color="#020202"/>
        </radialGradient>

        <linearGradient id="metalEngraved" x1="-300" y1="-300" x2="300" y2="300">
          <stop offset="0%" stop-color="#444"/>
          <stop offset="50%" stop-color="#111"/>
          <stop offset="100%" stop-color="#333"/>
        </linearGradient>

        <linearGradient id="metalSilver" x1="-150" y1="-150" x2="150" y2="150">
          <stop offset="0%" stop-color="#ffffff"/>
          <stop offset="25%" stop-color="#88888b"/>
          <stop offset="50%" stop-color="#cccccc"/>
          <stop offset="75%" stop-color="#444447"/>
          <stop offset="100%" stop-color="#ffffff"/>
        </linearGradient>

        <linearGradient id="metalDark" x1="-400" y1="-400" x2="400" y2="400">
          <stop offset="0%" stop-color="#333"/>
          <stop offset="40%" stop-color="#1a1a1c"/>
          <stop offset="100%" stop-color="#000"/>
        </linearGradient>

        <!-- Cyan energy glow filter -->
        <filter id="cyanGlow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur in="SourceGraphic" stdDeviation="10" result="blur1"/>
          <feGaussianBlur in="SourceGraphic" stdDeviation="20" result="blur2"/>
          <feGaussianBlur in="SourceGraphic" stdDeviation="40" result="blur3"/>
          <feMerge>
            <feMergeNode in="blur3"/>
            <feMergeNode in="blur2"/>
            <feMergeNode in="blur1"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>

        <!-- Drop shadow for depth -->
        <filter id="shadowDepth" x="-10%" y="-10%" width="120%" height="120%">
          <feDropShadow dx="0" dy="8" stdDeviation="15" flood-color="#000" flood-opacity="0.8"/>
        </filter>
        <filter id="shadowDeep" x="-20%" y="-20%" width="140%" height="140%">
          <feDropShadow dx="15" dy="25" stdDeviation="25" flood-color="#000" flood-opacity="0.9"/>
        </filter>

        <!-- Text Paths -->
        <!-- Outer text path: Radius 320 -->
        <path id="textPathOuterTop" d="M -320 0 A 320 320 0 0 1 320 0"/>
        <path id="textPathOuterBottom" d="M 320 0 A 320 320 0 0 1 -320 0"/>
        
        <!-- Inner binary path: Radius 230 -->
        <path id="textPathInnerTop" d="M -230 0 A 230 230 0 0 1 230 0"/>
        <path id="textPathInnerBottom" d="M 230 0 A 230 230 0 0 1 -230 0"/>
      </defs>

      <!-- LAYER 1: Background Plate -->
      <g class="layer-plate" filter="url(#shadowDeep)">
        <!-- The core dark stone slab -->
        <circle cx="0" cy="0" r="430" fill="url(#plateGrad)"/>
        <!-- Ring delineators for depth -->
        <circle cx="0" cy="0" r="390" fill="none" stroke="#222" stroke-width="4"/>
        <circle cx="0" cy="0" r="380" fill="none" stroke="#000" stroke-width="12"/>
        <circle cx="0" cy="0" r="372" fill="none" stroke="#2a2a2d" stroke-width="2"/>
        <!-- Rough cracks/details could go here -->
      </g>

      <!-- LAYER 2: Outer Engraved Disc (Static text and symbols) -->
      <g class="layer-engraved-disc">
        <!-- Text: CLARITY ⚙ SYSTEMS ⚙ MOMENTUM -->
        <!-- Upper arc -->
        <text font-family="'Space Grotesk', sans-serif" font-size="34" font-weight="600" letter-spacing="14" fill="url(#metalEngraved)" filter="url(#shadowDepth)">
          <textPath href="#textPathOuterTop" startOffset="50%" text-anchor="middle">
            CLARITY <tspan fill="#333" font-size="28">❂</tspan> SYSTEMS <tspan fill="#333" font-size="28">❂</tspan> MOMENTUM
          </textPath>
        </text>
        <!-- Lower arc -->
        <text font-family="'Space Grotesk', sans-serif" font-size="34" font-weight="600" letter-spacing="14" fill="url(#metalEngraved)" filter="url(#shadowDepth)">
          <textPath href="#textPathOuterBottom" startOffset="50%" text-anchor="middle">
            CLARITY <tspan fill="#333" font-size="28">❂</tspan> SYSTEMS <tspan fill="#333" font-size="28">❂</tspan> MOMENTUM
          </textPath>
        </text>

        <!-- Compass/Arrow markers North & South -->
        <g class="compass-marker" transform="translate(0, -290)">
          <path d="M 0 -40 L 25 15 L 5 15 L 5 45 L -5 45 L -5 15 L -25 15 Z" fill="url(#metalEngraved)" filter="url(#shadowDepth)"/>
          <line x1="-30" y1="5" x2="30" y2="5" stroke="#111" stroke-width="3"/>
        </g>
        <g class="compass-marker" transform="translate(0, 290) rotate(180)">
          <path d="M 0 -40 L 25 15 L 5 15 L 5 45 L -5 45 L -5 15 L -25 15 Z" fill="url(#metalEngraved)" filter="url(#shadowDepth)"/>
          <line x1="-30" y1="5" x2="30" y2="5" stroke="#111" stroke-width="3"/>
        </g>
      </g>

      <!-- LAYER 4: Inner Technical Ring (Counter-clockwise rotation) -->
      <g class="layer-tech-ring rot-ccw">
        <circle cx="0" cy="0" r="255" fill="none" stroke="#222" stroke-width="3"/>
        <circle cx="0" cy="0" r="235" fill="none" stroke="#222" stroke-width="1"/>
        
        <!-- Circuit lines & tech vias -->
        <g stroke="#3a3a40" stroke-width="2" fill="none">
          <!-- Top left trace -->
          <path d="M -150 -180 L -120 -150 L -60 -150 L -40 -110"/>
          <circle cx="-40" cy="-110" r="4" fill="#3a3a40"/>
          <!-- Top right trace -->
          <path d="M 160 -170 L 130 -140 L 80 -140 L 50 -100"/>
          <rect x="47" y="-103" width="6" height="6" fill="#3a3a40"/>
          <!-- Bottom traces -->
          <path d="M -160 160 L -130 130 L -90 130 L -70 100"/>
          <circle cx="-70" cy="100" r="4" fill="#3a3a40"/>
          <path d="M 150 180 L 120 150 L 60 150 L 40 110"/>
          <rect x="37" y="107" width="6" height="6" fill="#3a3a40"/>
          
          <!-- Abstract component blocks on the ring -->
          <rect x="-190" y="-12" width="24" height="24" fill="none" stroke="#3a3a40" stroke-width="2"/>
          <rect x="-186" y="-8" width="16" height="16" fill="#111" stroke="#3a3a40" stroke-width="1"/>
          
          <rect x="166" y="-12" width="24" height="24" fill="none" stroke="#3a3a40" stroke-width="2"/>
          <rect x="170" y="-8" width="16" height="16" fill="#111" stroke="#3a3a40" stroke-width="1"/>
        </g>

        <!-- Binary code encircling -->
        <text font-family="'JetBrains Mono', monospace" font-size="12" font-weight="500" letter-spacing="4" fill="#333">
          <textPath href="#textPathInnerTop" startOffset="50%" text-anchor="middle">
            01101100 01101111 01100111 01110011
          </textPath>
        </text>
        <text font-family="'JetBrains Mono', monospace" font-size="12" font-weight="500" letter-spacing="4" fill="#333">
          <textPath href="#textPathInnerBottom" startOffset="50%" text-anchor="middle">
            10010111 11010010 00110101 10101001
          </textPath>
        </text>

        <!-- Deep dark inner plate before the emblem -->
        <circle cx="0" cy="0" r="190" fill="url(#metalDark)" filter="url(#shadowDepth)"/>
        <!-- Fine technical hash marks -->
        <g stroke="#222" stroke-width="1">
          {Array.from({length: 36}).map((_, i) => (
            <line 
              x1={180 * Math.cos(i * 10 * Math.PI/180)} 
              y1={180 * Math.sin(i * 10 * Math.PI/180)} 
              x2={190 * Math.cos(i * 10 * Math.PI/180)} 
              y2={190 * Math.sin(i * 10 * Math.PI/180)} 
            />
          ))}
        </g>
      </g>
      
      <!-- LAYER 5: Center BII Emblem (Static, metallic) -->
      <!-- The main visual anchor -->
      <g class="layer-emblem" filter="url(#shadowDepth)">
        <!-- Horizontal grid line -->
        <line x1="-150" y1="0" x2="150" y2="0" stroke="#333" stroke-width="1"/>
        <line x1="0" y1="-150" x2="0" y2="150" stroke="#333" stroke-width="1"/>

        <!-- The BII Lettermark Custom SVG -->
        <g transform="translate(-15, 0)">
          <!-- Left sharp serif details of the B -->
          <path d="M-60 -75 L-50 -65 L-50 65 L-60 75 Z" fill="url(#metalSilver)"/>
          
          <!-- B main body -->
          <path d="M -50 -65 
                   L -5 -65 
                   C 15 -65, 30 -50, 30 -30 
                   C 30 -15, 20 -5, 5 0 
                   C 30 5, 45 20, 45 40 
                   C 45 60, 25 65, -5 65 
                   L -50 65 Z 
                   M -20 -45 L -20 -15 L 0 -15 C 5 -15, 10 -20, 10 -30 C 10 -40, 5 -45, 0 -45 Z
                   M -20 10 L -20 45 L 0 45 C 10 45, 15 40, 15 28 C 15 15, 10 10, 0 10 Z" 
                fill="url(#metalSilver)"/>
                
          <!-- Accent spike between top/bottom B loops -->
          <path d="M-55 0 L-20 0 L-30 -10 Z" fill="#222"/>
          <path d="M-55 0 L-20 0 L-30 10 Z" fill="#111"/>
        </g>
        
        <!-- The II columns -->
        <g transform="translate(60, 0)">
          <rect x="0" y="-65" width="12" height="130" fill="url(#metalSilver)"/>
          <rect x="25" y="-65" width="12" height="130" fill="url(#metalSilver)"/>
          <!-- Top serifs -->
          <polygon points="-5,-65 17,-65 12,-60 0,-60" fill="url(#metalSilver)"/>
          <polygon points="20,-65 42,-65 37,-60 25,-60" fill="url(#metalSilver)"/>
          <!-- Bottom serifs -->
          <polygon points="-5,65 17,65 12,60 0,60" fill="url(#metalSilver)"/>
          <polygon points="20,65 42,65 37,60 25,60" fill="url(#metalSilver)"/>
        </g>
      </g>

      <!-- LAYER 6: B Flicker/Glow Overlay -->
      <g class="layer-emblem-flicker">
        <!-- Re-use the B geometry but stroke it with cyan and apply glow -->
        <g transform="translate(-15, 0)" filter="url(#cyanGlow)" opacity="0">
          <path d="M -50 -65 
                   L -5 -65 
                   C 15 -65, 30 -50, 30 -30 
                   C 30 -15, 20 -5, 5 0 
                   C 30 5, 45 20, 45 40 
                   C 45 60, 25 65, -5 65 
                   L -50 65 Z" 
                fill="none" stroke="#00f3ff" stroke-width="4" stroke-linejoin="miter" stroke-miterlimit="4"/>
        </g>
      </g>

      <!-- LAYER 3: Outer Wreath / Thorn Crown (Clockwise rotation) -->
      <!-- Placed last in SVG so it overlays the engraved plate visually, but below the B in z-index mentally; 
           actually the wreath from the reference overlaps the ring but NOT the center emblem. Let's make it cover the engraved disc. -->
      <g class="layer-wreath rot-cw" filter="url(#shadowDeep)">
        <!-- Generate procedural overlapping thorny vines using multiple <path> arcs -->
        {Array.from({length: 24}).map((_, i) => {
          const rotation = i * 15;
          return (
            <g transform={`rotate(${rotation})`}>
              <!-- Main vine swoop -->
              <path d="M 330 0 C 350 40, 340 100, 300 120" fill="none" stroke="url(#metalDark)" stroke-width="10" stroke-linecap="round"/>
              <path d="M 330 0 C 350 40, 340 100, 300 120" fill="none" class="thorn-highlight" stroke-width="2"/>
              <!-- Thorns branching off -->
              <path d="M 340 50 Q 360 40 370 20 Q 345 45 330 60" fill="url(#plateGrad)"/>
              <path d="M 320 80 Q 290 90 280 110 Q 310 95 315 70" fill="url(#plateGrad)"/>
            </g>
          )
        })}
        <!-- Outer chaotic roots / tendrils breaking the perfect circle -->
        {Array.from({length: 8}).map((_, i) => {
          const rotation = i * 45 + 22.5;
          return (
            <g transform={`rotate(${rotation}) translate(330, 0)`}>
              <path d="M 0 0 C 50 20, 80 -20, 110 30 C 90 10, 50 40, 0 0" fill="none" stroke="url(#metalDark)" stroke-width="6"/>
              <path d="M 20 10 C 60 50, 70 80, 50 110" fill="none" stroke="url(#metalDark)" stroke-width="4"/>
            </g>
          )
        })}
      </g>

    </svg>
  </div>

  <!-- Content overlaid on the hero section -->
  <div class="hero-content">
    <div class="hero-content-inner">
      <h1 class="hero-name">{siteConfig.name}</h1>
      <p class="hero-tagline">{siteConfig.tagline}</p>
      <p class="hero-description">{siteConfig.description}</p>
      <div class="hero-ctas">
        <a href="/projects" class="hero-cta hero-cta--primary">
          View Projects <span aria-hidden="true">→</span>
        </a>
        <a href="/connect" class="hero-cta hero-cta--secondary">Book a Call</a>
      </div>
    </div>
  </div>
  
  <div class="hero-fade-bottom"></div>
</section>

<style>
  /* ==========================================
     LAYOUT & ATMOSPHERE
     ========================================== */
  .hero-seal-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: #020202;
    overflow: hidden;
  }

  .seal-atmos {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .blur-bg {
    background: radial-gradient(circle at 75% 50%, rgba(0, 243, 255, 0.05) 0%, transparent 40%),
                radial-gradient(circle at 25% 60%, rgba(0, 102, 255, 0.04) 0%, transparent 50%);
  }

  .noise-overlay {
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    mix-blend-mode: overlay;
  }

  .scanlines {
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 243, 255, 0.02) 3px,
      rgba(0, 243, 255, 0.02) 4px
    );
    opacity: 0;
    animation: fade-in 2s ease 1s forwards;
  }

  /* ==========================================
     SEAL CONTAINER & SVG STYLES
     ========================================== */
  .seal-container {
    position: absolute;
    top: 50%;
    right: -10%; /* Offset to the right to leave room for text */
    transform: translateY(-50%);
    width: min(900px, 120vw);
    height: min(900px, 120vw);
    z-index: 1;
    opacity: 0;
    animation: scale-in-fade 1.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @media (max-width: 1024px) {
    .seal-container {
      right: -20%;
      width: min(800px, 140vw);
      height: min(800px, 140vw);
    }
  }

  @media (max-width: 768px) {
    .seal-container {
      top: 30%;
      right: 50%;
      transform: translate(50%, -50%);
      width: min(600px, 120vw);
      height: min(600px, 120vw);
      opacity: 0.3; /* Wash out slightly on mobile to read text over it */
    }
  }

  .seal-svg {
    width: 100%;
    height: 100%;
    /* Subtle hover tilt effect */
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .seal-container:hover .seal-svg {
    transform: perspective(1000px) rotateX(2deg) rotateY(-5deg) scale(1.02);
  }

  /* SVG Specific Overrides */
  .thorn-highlight {
    stroke: #555;
    mix-blend-mode: color-dodge;
  }

  /* ==========================================
     ANIMATION CLASSES
     ========================================== */
  
  /* Outer wreath rotates clockwise very slowly */
  .rot-cw {
    transform-origin: 0 0;
    animation: spin-cw 180s linear infinite;
  }

  /* Inner tech ring rotates counter-clockwise */
  .rot-ccw {
    transform-origin: 0 0;
    animation: spin-ccw 140s linear infinite;
  }

  /* The B flicker/pulse effect */
  .layer-emblem-flicker > g {
    animation: tech-flicker 6s infinite;
  }

  /* ==========================================
     KEYFRAMES
     ========================================== */
  @keyframes spin-cw {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes spin-ccw {
    from { transform: rotate(0deg); }
    to { transform: rotate(-360deg); }
  }

  @keyframes fade-in {
    to { opacity: 1; }
  }

  @keyframes scale-in-fade {
    from { 
      opacity: 0; 
      transform: translateY(-50%) scale(0.9) rotate(-5deg); 
    }
    to { 
      opacity: 1; 
      transform: translateY(-50%) scale(1) rotate(0deg); 
    }
  }

  /* Irregular technological pulse */
  @keyframes tech-flicker {
    0%, 9% { opacity: 0; }
    10% { opacity: 0.8; }
    12% { opacity: 0.2; }
    14% { opacity: 0.9; }
    16%, 40% { opacity: 0; }
    41% { opacity: 0.4; }
    43%, 60% { opacity: 0; }
    61% { opacity: 1; }
    63% { opacity: 0.1; }
    65% { opacity: 0.7; }
    68%, 100% { opacity: 0; }
  }

  /* Text entry animations */
  @keyframes slide-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ==========================================
     CONTENT STYLING
     ========================================== */
  .hero-content {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hero-content-inner {
    max-width: 500px;
    padding-top: 5rem;
  }

  @media (max-width: 768px) {
    .hero-content-inner {
      padding-top: 15rem; /* Push down past centered logo */
      position: relative;
      z-index: 20;
    }
  }

  .hero-name {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 700;
    line-height: 1;
    color: #f0f0f0;
    margin-bottom: 1rem;
    opacity: 0;
    animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
    text-shadow: 0 4px 20px rgba(0,0,0,0.8);
  }

  .hero-tagline {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(0.7rem, 1.2vw, 0.85rem);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #00f3ff;
    margin-bottom: 2rem;
    opacity: 0;
    animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.7s forwards;
  }

  .hero-description {
    font-size: 1.1rem;
    line-height: 1.6;
    color: #a0a0;
    margin-bottom: 2.5rem;
    opacity: 0;
    color: #a0a0a0;
    animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.9s forwards;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 1.1s forwards;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.8rem;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .hero-cta--primary {
    background: #00f3ff;
    color: #050508;
  }
  .hero-cta--primary:hover {
    box-shadow: 0 0 20px rgba(0, 243, 255, 0.4);
    transform: translateY(-2px);
  }

  .hero-cta--secondary {
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #e0e0e0;
  }
  .hero-cta--secondary:hover {
    border-color: #00f3ff;
    color: #00f3ff;
    background: rgba(0, 243, 255, 0.05);
  }

  .hero-fade-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 150px;
    background: linear-gradient(to bottom, transparent, #0a0a0a);
    z-index: 5;
    pointer-events: none;
  }

  /* ==========================================
     REDUCED MOTION
     ========================================== */
  @media (prefers-reduced-motion: reduce) {
    .rot-cw, .rot-ccw, .layer-emblem-flicker > g {
      animation: none !important;
    }
    .seal-container, .hero-name, .hero-tagline, .hero-description, .hero-ctas, .scanlines {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>
