---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/Section.astro';
import SkillCard from '../components/SkillCard.astro';
import QuoteBlock from '../components/QuoteBlock.astro';
import { skills, skillTags } from '../data/site';
---

<BaseLayout title="About" description="About Max Wels — data, systems, automation, and building a life with structure and freedom.">
  <Nav slot="nav" />

  <!-- Page Hero -->
  <section class="pt-16 md:pt-24 pb-12 relative">
    <div class="mx-auto max-w-[1200px] px-6 md:px-10">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-green mb-3 reveal-on-scroll">
        About
      </p>
      <h1 class="font-display text-[clamp(2rem,5vw,3.5rem)] font-bold tracking-tight text-text-primary leading-[1.1] mb-6 reveal-on-scroll">
        Not just a freelancer.<br />Not just a traveler.
      </h1>
    </div>
  </section>

  <!-- Main About -->
  <Section class="border-t border-border">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-20">
      <!-- Text -->
      <div class="lg:col-span-3 reveal-on-scroll">
        <div class="prose prose-invert max-w-none">
          <p class="text-text-secondary text-base md:text-lg leading-relaxed mb-6">
            I'm someone who likes building things that create clarity — in work, in systems, and in life.
          </p>
          <p class="text-text-secondary text-base md:text-lg leading-relaxed mb-6">
            My background combines project work, operations, data analysis and product thinking. I'm especially interested in automation, AI-supported workflows, and practical solutions that help people work smarter.
          </p>
          <p class="text-text-secondary text-base md:text-lg leading-relaxed mb-6">
            Outside of work, I'm drawn to movement, music, culture and freedom. I train calisthenics, love intense experiences, travel whenever I can, and care about building a life that feels real instead of just optimized.
          </p>
          <p class="text-text-secondary text-base md:text-lg leading-relaxed">
            I'm interested in projects, people and places with energy, depth and direction.
          </p>
        </div>
      </div>

      <!-- Portrait -->
      <div class="lg:col-span-2">
        <div class="sticky top-24">
          <div class="relative aspect-[3/4] rounded-sm overflow-hidden bg-bg-elevated border border-border reveal-on-scroll">
            <img
              src="/images/portrait-placeholder.jpg"
              alt="Max Wels"
              class="w-full h-full object-cover opacity-80"
              loading="lazy"
              onerror="this.style.display='none'; this.parentElement.classList.add('flex','items-center','justify-center'); const s = document.createElement('span'); s.className='text-text-muted text-xs font-mono text-center px-4'; s.textContent='[ Replace with portrait: /public/images/portrait-placeholder.jpg ]'; this.parentElement.appendChild(s);"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-bg-primary/20 to-transparent"></div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Quote -->
  <Section compact class="border-t border-border">
    <div class="max-w-3xl reveal-on-scroll">
      <QuoteBlock
        text="I value independence, depth, curiosity, self-development and a certain kind of edge."
      />
    </div>
  </Section>

  <!-- Skills -->
  <Section title="What I do" subtitle="Skills & expertise" class="border-t border-border">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 stagger-children">
      {skills.map((skill) => (
        <SkillCard
          title={skill.title}
          description={skill.description}
          icon={skill.icon}
        />
      ))}
    </div>

    <!-- Skill tags -->
    <div class="mt-10 flex flex-wrap gap-2 reveal-on-scroll">
      {skillTags.map((tag) => (
        <span class="font-mono text-[11px] tracking-wider text-text-muted px-3 py-1.5 border border-border-subtle rounded-sm">
          {tag}
        </span>
      ))}
    </div>
  </Section>

  <!-- Values -->
  <Section title="What drives me" subtitle="Values" class="border-t border-border" compact>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 md:gap-12 reveal-on-scroll">
      <div>
        <h3 class="font-display text-base font-semibold text-text-primary mb-2">Clarity over complexity</h3>
        <p class="text-sm text-text-secondary leading-relaxed">I believe the best systems, tools, and decisions create simplicity — not more noise.</p>
      </div>
      <div>
        <h3 class="font-display text-base font-semibold text-text-primary mb-2">Freedom with structure</h3>
        <p class="text-sm text-text-secondary leading-relaxed">I want independence, but not chaos. Good routines and systems create space for real freedom.</p>
      </div>
      <div>
        <h3 class="font-display text-base font-semibold text-text-primary mb-2">Depth over surface</h3>
        <p class="text-sm text-text-secondary leading-relaxed">I'd rather go deep than wide. Quality matters — in work, relationships, and experiences.</p>
      </div>
      <div>
        <h3 class="font-display text-base font-semibold text-text-primary mb-2">Real over polished</h3>
        <p class="text-sm text-text-secondary leading-relaxed">I care about authenticity. Not everything needs to be perfect — but it should be honest.</p>
      </div>
    </div>
  </Section>

  <Footer slot="footer" />
</BaseLayout>
